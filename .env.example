# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
SESSION_SECRET=your-secret-key-here

# S3 Storage (optional - if not set, files will be stored locally)
# For AWS S3:
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_PUBLIC_URL=https://your-bucket.s3.us-east-1.amazonaws.com

# For S3-compatible services (e.g., DigitalOcean Spaces, Railway S3):
# S3_BUCKET=your-bucket-name
# S3_REGION=nyc3
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# S3_FORCE_PATH_STYLE=false
# S3_PUBLIC_URL=https://your-bucket.nyc3.digitaloceanspaces.com
# S3_ACCESS_KEY_ID=your-spaces-key
# S3_SECRET_ACCESS_KEY=your-spaces-secret

# Image uploads (optional tuning)
# IMAGE_UPLOAD_MAX_EDGE_PX=1920
# IMAGE_UPLOAD_JPEG_QUALITY=82
# IMAGE_UPLOAD_OPTIMIZE_MIN_BYTES=20480

# List thumbnails (GET /api/image-preview) — JPEG max edge; optional query &max=160–800 for card heroes
# IMAGE_LIST_PREVIEW_MAX_PX=384
# IMAGE_LIST_PREVIEW_JPEG_QUALITY=78
# IMAGE_LIST_PREVIEW_MAX_INPUT_BYTES=20971520
# IMAGE_LIST_PREVIEW_LRU=100

# Observability (optional)
# MEDIA_PROXY_SLOW_LOG_MS=2500
# S3_UPLOAD_WARN_MS=5000
